# API credentials for the Eurovision enrichment pipeline.
#
# 1. Copy this file to `.env` (just `.env`, no `.example`)
# 2. Paste your real values between the quotes below
# 3. Save the file
#
# Never commit .env to git — it's in .gitignore for that reason.

# ─── Spotify Web API ─────────────────────────────────────────────────────────
# Get from: https://developer.spotify.com/dashboard
#   - Click "Create app"
#   - Set Redirect URI to https://localhost:8080
#   - Tick "Web API"
#   - After creating, click Settings → "View client secret"
SPOTIFY_CLIENT_ID="paste_your_client_id_here"
SPOTIFY_CLIENT_SECRET="paste_your_client_secret_here"


# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
#   1. Create a project (or pick existing)
#   2. "Enabled APIs & services" → search "YouTube Data API v3" → Enable
#   3. "Credentials" → "Create credentials" → "API key"
#   4. Copy and paste below
YOUTUBE_API_KEY="paste_your_youtube_api_key_here"


# ─── Last.fm API (alternative popularity signal — playcount + listeners) ────
# Get from: https://www.last.fm/api/account/create
#   - Free, instant signup, no credit card
#   - Only the API key is needed (we don't use the shared secret)
LASTFM_API_KEY="paste_your_lastfm_api_key_here"
